# .env.example — FIXED (CRIT-04)
# Renamed from env.example.production → .env.example
# Copy to .env and fill in real values before running docker compose

# ── Database ──────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_strong_root_password
DB_USER=inphora_user

# Per-tenant DB passwords (generated by init_databases.sh)
DB_NAME_TYTAHJ=tytahjdb
DB_PASSWORD_TYTAHJ=change_me

DB_NAME_AMARIFLOW=amaridb
DB_PASSWORD_AMARIFLOW=change_me

DB_NAME_IL=ildb
DB_PASSWORD_IL=change_me

# ── JWT Secret Keys ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY_TYTAHJ=generate_with_openssl_rand_hex_32
SECRET_KEY_AMARIFLOW=generate_with_openssl_rand_hex_32
SECRET_KEY_IL=generate_with_openssl_rand_hex_32

# ── Token Expiry ──────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Environment ───────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Domains ───────────────────────────────────────────────────────────────
DOMAIN_TYTAHJ=tytahj.inphora.net
DOMAIN_AMARIFLOW=amariflow.inphora.net
DOMAIN_IL=il.inphora.net
